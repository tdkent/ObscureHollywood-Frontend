{
  "name": "obscurehollywood-frontend",
  "description": "Frontend UI for the ObscureHollywood website.",
  "author": "Tim Kent <timkentdev@gmail.com>",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "biome check --verbose",
    "lint:fix": "biome check --write --no-errors-on-unmatched",
    "preview": "vite preview",
    "test": "vitest",
    "prepare": "husky",
    "knip": "knip"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --verbose"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-router": "^7.14.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
